{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "paths": {
      "@agencecinq/utils": [
        "../utils/src/index.ts"
      ]
    }
  },
  "references": [
    {
      "path": "../utils"
    }
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ],
  "moduleResolution": "bundler"
}